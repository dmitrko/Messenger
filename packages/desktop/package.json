{
    "name": "@nostachat/desktop",
    "version": "1.0.0",
    "private": true,
    "main": "main.js",
    "type": "commonjs",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently \"npm.cmd run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
        "electron:build": "npm.cmd run build && electron-builder --win"
    },
    "dependencies": {
        "@nostachat/shared": "*",
        "@types/simple-peer": "^9.11.9",
        "buffer": "^6.0.3",
        "crystals-kyber-js": "^2.7.0",
        "dexie": "^4.4.2",
        "dexie-react-hooks": "^4.4.0",
        "libsodium-wrappers": "^0.8.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-draggable": "^4.5.0",
        "simple-peer": "^9.11.1"
    },
    "devDependencies": {
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.7.0",
        "concurrently": "^9.2.1",
        "cross-env": "^7.0.3",
        "electron": "31.7.7",
        "electron-builder": "^26.8.1",
        "typescript": "^5.9.3",
        "vite": "^5.4.21",
        "wait-on": "^9.0.4"
    },
    "build": {
        "appId": "com.nostachat.desktop",
        "productName": "NostaChat",
        "electronVersion": "31.7.7",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "dist/**/*",
            "main.js",
            "preload.js",
            "public/assets/icq-classic/flower.png"
        ],
        "win": {
            "target": [
                "portable"
            ],
            "icon": "public/assets/icq-classic/flower.png"
        }
    }
}
